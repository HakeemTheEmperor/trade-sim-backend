# =============================================================================
# Trade Sim Backend — environment variables
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Loaded via python-dotenv in app/__init__.py and by docker-compose (env_file).
# =============================================================================

# --- Database --------------------------------------------------------------
# Postgres credentials + database name. Under docker-compose these configure the
# `db` service AND are interpolated into SQLALCHEMY_DATABASE_URI for the app
# service (docker-compose.yml derives the URI from them, so there's a single
# source of truth and the two can't drift).
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=myappdb

# Postgres major version for the db service image. Pinned (not `latest`) so an
# upstream bump can't refuse to open a volume created by an older version.
POSTGRES_VERSION=16

# Published host ports (host:container). Change these if 5432/5000 are already
# taken on your machine; they don't affect the in-network URI, which always uses
# the container's internal 5432.
DB_PORT=5432
APP_PORT=5000

# SQLAlchemy connection string. Used directly when running OUTSIDE docker (local
# pipenv). Under docker-compose it is overridden by the value built from the
# POSTGRES_* vars above (host = the `db` service). Keep the two consistent.
SQLALCHEMY_DATABASE_URI=postgresql://admin:secret@db:5432/myappdb
# Leave "False" unless you need SQLAlchemy modification tracking.
SQLALCHEMY_TRACK_MODIFICATIONS=False

# --- Auth / JWT ------------------------------------------------------------
# Secret used to sign JWTs. SERVER-ONLY — never expose this to the client.
# Must be long and random; anyone with it can forge tokens for any user/role.
JWT_SECRET_KEY=change-me-to-a-long-random-string
# Access token lifetime in hours (default 6).
JWT_ACCESS_TOKEN_EXPIRES=6

# The JWT is stored in an HttpOnly cookie. Keep Secure=True in production (HTTPS);
# set False only for local dev over http:// or the browser won't store the cookie.
JWT_COOKIE_SECURE=True
# SameSite policy. "Lax" is correct when FE and BE share a registrable domain
# (e.g. app.imockmarket.toluwalase.me + api.imockmarket.toluwalase.me).
JWT_COOKIE_SAMESITE=Lax

# --- Seed admin user -------------------------------------------------------
# Super-admin account created on startup (app/__init__.py: create_admin()).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Swagger UI ------------------------------------------------------------
# URL prefix the Swagger UI is served under (e.g. /docs) ...
SWAGGER_URL=/docs
# ... and the path to the OpenAPI spec it loads (e.g. /static/openapi.yaml).
API_URL=/static/openapi.yaml

# --- App / CORS ------------------------------------------------------------
# Comma-separated list of allowed browser origins. Must be explicit (never "*")
# because cookie auth uses credentialed requests. Set the deployed frontend
# origin plus your local dev origin.
# NOTE: cookie auth requires FE and BE to be same-site (same registrable
# domain), e.g. app.imockmarket.toluwalase.me + api.imockmarket.toluwalase.me.
CORS_ORIGINS=https://app.imockmarket.toluwalase.me,http://localhost:5173
# Logging verbosity (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
# Whether this process runs the price scheduler + Finnhub websocket listener.
# Keep "true" for the single-process deployment; set "false" on extra web
# workers/instances so only one process runs the background jobs.
RUN_BACKGROUND_JOBS=true

# --- External market-data providers ---------------------------------------
# All provider endpoints are assembled in ONE place: app/integrations/providers.py.
# Only base URLs + keys live here; the endpoint paths live in that module. Leave
# the *_BASE_URL / *_WS_URL values unset to use the built-in defaults; override
# only to point at a sandbox or a different API version.

# Financial Modeling Prep — used to seed available stock prices (app/data_seed.py).
FMP_API_KEY=
# Optional base override (default: https://financialmodelingprep.com/stable).
FMP_BASE_URL=

# Finnhub real-time price websocket (app/websocket_listener.py).
FINNHUB_WS_URL=wss://ws.finnhub.io
FINNHUB_API_KEY=

# Polygon.io — used to backfill daily price history (app/utils/update_history.py).
POLYGON_API_KEY=
# Optional base override (default: https://api.polygon.io).
POLYGON_BASE_URL=

# Currency exchange-rate API (exchangerate-api.com). Base URL INCLUDING the key
# segment but WITHOUT a trailing /pair or /latest, e.g.
#   https://v6.exchangerate-api.com/v6/YOUR-KEY
# The app calls /latest/{base} (one request returns all target rates) and caches
# each rate until the provider's own time_next_update_unix, so on the free tier
# (daily updates) it uses ~1 request/day and is never staler than the data itself.
EXCHANGE_RATE_API=
# Fallback freshness window (hours) used only when a cached rate has no
# next_update timestamp. Default 24.
EXCHANGE_RATE_TTL_HOURS=24
